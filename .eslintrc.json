{
  "env": {
    "browser": true,
    "node": true,
    "es2022": true,
    "cypress/globals": true
  },
  "extends": ["eslint:recommended", "plugin:node/recommended", "plugin:cypress/recommended", "prettier"],
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "plugins": ["cypress"],
  "rules": {
    "no-unused-vars": ["warn"],
    "node/no-unpublished-require": "off",
    "cypress/unsafe-to-chain-command": "off"
  }
}
